<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ColimaDesktop.Windows.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ColimaDesktop.Windows.Views"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16">
            <TextBlock Text="Dashboard" Style="{ThemeResource TitleTextBlockStyle}"
                       AutomationProperties.Name="DashboardTitle" />

            <!-- Status Banner -->
            <InfoBar x:Name="ErrorBar"
                     AutomationProperties.Name="ErrorBanner"
                     IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                     Severity="Error"
                     Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                     Title="Error" />

            <!-- VM Status Card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="VM Status" Style="{ThemeResource SubtitleTextBlockStyle}"
                               AutomationProperties.Name="VMStatusHeader" />
                    <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                  AutomationProperties.Name="LoadingIndicator" />
                    <StackPanel Spacing="6" Visibility="{x:Bind ViewModel.VmStatus, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                        <TextBlock AutomationProperties.Name="VMStatusRunning"
                                   Text="{x:Bind ViewModel.VmStatus.Running, Mode=OneWay, Converter={StaticResource BoolToStatusConverter}}" />
                        <TextBlock AutomationProperties.Name="VMStatusName"
                                   Text="{x:Bind ViewModel.VmStatus.DisplayName, Mode=OneWay}" />
                        <TextBlock AutomationProperties.Name="VMStatusRuntime"
                                   Text="{x:Bind ViewModel.VmStatus.Runtime, Mode=OneWay}" />
                        <TextBlock AutomationProperties.Name="VMStatusArch"
                                   Text="{x:Bind ViewModel.VmStatus.Arch, Mode=OneWay}" />
                        <TextBlock AutomationProperties.Name="VMStatusIP"
                                   Text="{x:Bind ViewModel.VmStatus.IpAddress, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Lifecycle Buttons -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Content="Start"
                            AutomationProperties.Name="BtnStartVM"
                            Command="{x:Bind ViewModel.StartCommand}"
                            Style="{ThemeResource AccentButtonStyle}" />
                    <Button Content="Stop"
                            AutomationProperties.Name="BtnStopVM"
                            Command="{x:Bind ViewModel.StopCommand}" />
                    <Button Content="Restart"
                            AutomationProperties.Name="BtnRestartVM"
                            Command="{x:Bind ViewModel.RestartCommand}" />
                    <Button Content="SSH Config"
                            AutomationProperties.Name="BtnSSHConfig"
                            Command="{x:Bind ViewModel.ShowSshConfigCommand}" />
                </StackPanel>
            </Border>

            <!-- Progress -->
            <StackPanel Spacing="8"
                        Visibility="{x:Bind ViewModel.IsProgressVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock AutomationProperties.Name="ProgressMessage"
                           Text="{x:Bind ViewModel.ProgressMessage, Mode=OneWay}" />
                <ProgressBar Value="{x:Bind ViewModel.ProgressValue, Mode=OneWay}"
                             Maximum="1"
                             AutomationProperties.Name="ProgressBar" />
            </StackPanel>

            <!-- SSH Config Panel -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    Visibility="{x:Bind ViewModel.SshConfig, Mode=OneWay, Converter={StaticResource EmptyStringToVisibilityConverter}}">
                <StackPanel Spacing="8">
                    <TextBlock Text="SSH Config" Style="{ThemeResource SubtitleTextBlockStyle}"
                               AutomationProperties.Name="SSHConfigHeader" />
                    <ScrollViewer Height="120">
                        <TextBlock Text="{x:Bind ViewModel.SshConfig, Mode=OneWay}"
                                   FontFamily="Cascadia Code, Consolas, monospace"
                                   AutomationProperties.Name="SSHConfigText"
                                   TextWrapping="Wrap" />
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- Version Info -->
            <TextBlock AutomationProperties.Name="VersionInfo"
                       Text="{x:Bind ViewModel.Version.Version, Mode=OneWay, FallbackValue=''}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
    </ScrollViewer>
</Page>
