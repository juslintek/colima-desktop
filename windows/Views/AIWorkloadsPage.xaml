<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ColimaDesktop.Windows.Views.AIWorkloadsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="700">
            <TextBlock Text="AI Workloads" Style="{ThemeResource TitleTextBlockStyle}"
                       AutomationProperties.Name="AIWorkloadsTitle" />

            <InfoBar AutomationProperties.Name="AIErrorBanner"
                     IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                     Severity="Error"
                     Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                     Title="Error" />

            <InfoBar AutomationProperties.Name="AIStatusBanner"
                     IsOpen="{x:Bind ViewModel.StatusMessage, Mode=OneWay, Converter={StaticResource NonEmptyToBoolConverter}}"
                     Severity="Informational"
                     Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                     Title="Status" />

            <!-- Model Config -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="Model" Style="{ThemeResource SubtitleTextBlockStyle}"
                               AutomationProperties.Name="AIModelHeader" />
                    <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto" RowSpacing="8">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Model name" VerticalAlignment="Center"
                                   AutomationProperties.Name="LabelModelName" />
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 AutomationProperties.Name="FieldModelName"
                                 PlaceholderText="e.g. llama3.2"
                                 Text="{x:Bind ViewModel.ModelName, Mode=TwoWay}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Runner" VerticalAlignment="Center"
                                   AutomationProperties.Name="LabelRunner" />
                        <ComboBox Grid.Row="1" Grid.Column="1"
                                  AutomationProperties.Name="FieldRunner"
                                  SelectedValue="{x:Bind ViewModel.Runner, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="docker" Tag="docker" />
                            <ComboBoxItem Content="ramalama" Tag="ramalama" />
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Actions -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="Actions" Style="{ThemeResource SubtitleTextBlockStyle}"
                               AutomationProperties.Name="AIActionsHeader" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Setup / Pull"
                                AutomationProperties.Name="BtnModelSetup"
                                Command="{x:Bind ViewModel.SetupModelCommand}"
                                Style="{ThemeResource AccentButtonStyle}" />
                        <Button Content="Run"
                                AutomationProperties.Name="BtnModelRun"
                                Command="{x:Bind ViewModel.RunModelCommand}" />
                        <Button Content="Stop"
                                AutomationProperties.Name="BtnModelStop"
                                Command="{x:Bind ViewModel.StopModelCommand}" />
                    </StackPanel>

                    <!-- Serve -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <NumberBox AutomationProperties.Name="FieldServePort"
                                   Value="{x:Bind ViewModel.ServePort, Mode=TwoWay}"
                                   Minimum="1024" Maximum="65535"
                                   Header="Port" Width="160" />
                        <Button Content="Serve"
                                AutomationProperties.Name="BtnModelServe"
                                Command="{x:Bind ViewModel.ServeModelCommand}" />
                    </StackPanel>

                    <!-- Progress -->
                    <StackPanel Spacing="4"
                                Visibility="{x:Bind ViewModel.IsProgressVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock AutomationProperties.Name="AIProgressMessage"
                                   Text="{x:Bind ViewModel.ProgressMessage, Mode=OneWay}" />
                        <ProgressBar AutomationProperties.Name="AIProgressBar"
                                     Value="{x:Bind ViewModel.ProgressValue, Mode=OneWay}" Maximum="1" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Run prompt -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="Prompt" Style="{ThemeResource SubtitleTextBlockStyle}"
                               AutomationProperties.Name="AIPromptHeader" />
                    <TextBox AutomationProperties.Name="FieldPrompt"
                             PlaceholderText="Enter prompt (leave empty for interactive)"
                             AcceptsReturn="True"
                             Height="80"
                             Text="{x:Bind ViewModel.Prompt, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <!-- Run Output -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Output" Style="{ThemeResource SubtitleTextBlockStyle}"
                               AutomationProperties.Name="AIOutputHeader" />
                    <ScrollViewer Height="200">
                        <TextBlock AutomationProperties.Name="AIOutputText"
                                   Text="{x:Bind ViewModel.RunOutput, Mode=OneWay}"
                                   FontFamily="Cascadia Code, Consolas, monospace"
                                   TextWrapping="Wrap" FontSize="11" />
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
