<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ColimaDesktop.Windows.Views.MachinesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid RowDefinitions="Auto,Auto,*" Padding="24" RowSpacing="12">
        <TextBlock Grid.Row="0" Text="Machines (Lima)" Style="{ThemeResource TitleTextBlockStyle}"
                   AutomationProperties.Name="MachinesTitle" />

        <InfoBar Grid.Row="0" Margin="0,40,0,0"
                 AutomationProperties.Name="MachinesErrorBanner"
                 IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                 Severity="Error"
                 Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                 Title="Error" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <Button Content="Refresh"
                    AutomationProperties.Name="BtnRefreshMachines"
                    Command="{x:Bind ViewModel.RefreshCommand}" />
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          AutomationProperties.Name="MachinesLoading"
                          Width="24" Height="24" />
        </StackPanel>

        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8" Padding="12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <StackPanel Spacing="8">
                <TextBlock Text="Lima Machines" Style="{ThemeResource SubtitleTextBlockStyle}"
                           AutomationProperties.Name="MachineListHeader" />
                <ItemsRepeater AutomationProperties.Name="MachineList"
                               ItemsSource="{x:Bind ViewModel.Machines.Machines, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1" Padding="4,8">
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <TextBlock Text="{Binding Name}" Width="140"
                                               AutomationProperties.Name="MachineName" />
                                    <TextBlock Text="{Binding Status}" Width="80"
                                               AutomationProperties.Name="MachineStatus" />
                                    <TextBlock Text="{Binding Arch}" Width="80"
                                               AutomationProperties.Name="MachineArch" />
                                    <TextBlock Text="{Binding Os}" Width="80"
                                               AutomationProperties.Name="MachineOs" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </Border>
    </Grid>
</Page>
