<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ColimaDesktop.Windows.Views.MonitoringPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="24" RowSpacing="12">
        <TextBlock Grid.Row="0" Text="Monitoring" Style="{ThemeResource TitleTextBlockStyle}"
                   AutomationProperties.Name="MonitoringTitle" />

        <InfoBar Grid.Row="0" Margin="0,40,0,0"
                 AutomationProperties.Name="MonitoringErrorBanner"
                 IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                 Severity="Error"
                 Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                 Title="Error" />

        <!-- Live VM Stats -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8" Padding="16"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <StackPanel Spacing="12">
                <TextBlock Text="Live VM Stats" Style="{ThemeResource SubtitleTextBlockStyle}"
                           AutomationProperties.Name="VMStatsHeader" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Start Stream"
                            AutomationProperties.Name="BtnStartStatsStream"
                            Command="{x:Bind ViewModel.StartStatsStreamCommand}"
                            Style="{ThemeResource AccentButtonStyle}" />
                    <Button Content="Stop Stream"
                            AutomationProperties.Name="BtnStopStatsStream"
                            Command="{x:Bind ViewModel.StopStatsStreamCommand}" />
                    <ProgressRing IsActive="{x:Bind ViewModel.IsStreaming, Mode=OneWay}"
                                  AutomationProperties.Name="StatsStreamActive"
                                  Width="24" Height="24" />
                </StackPanel>
                <!-- Stats Display -->
                <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" RowSpacing="4"
                      Visibility="{x:Bind ViewModel.LatestStats, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="CPU" FontWeight="SemiBold"
                               AutomationProperties.Name="StatsCPULabel" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Memory" FontWeight="SemiBold"
                               AutomationProperties.Name="StatsMemoryLabel" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Disk" FontWeight="SemiBold"
                               AutomationProperties.Name="StatsDiskLabel" />

                    <TextBlock Grid.Row="1" Grid.Column="0"
                               AutomationProperties.Name="StatsCPUValue"
                               Text="{x:Bind ViewModel.LatestStats.CpuPercent, Mode=OneWay, Converter={StaticResource PercentConverter}}" />
                    <TextBlock Grid.Row="1" Grid.Column="1"
                               AutomationProperties.Name="StatsMemoryValue"
                               Text="{x:Bind ViewModel.LatestStats.MemoryUsed, Mode=OneWay, Converter={StaticResource BytesToMBConverter}}" />
                    <TextBlock Grid.Row="1" Grid.Column="2"
                               AutomationProperties.Name="StatsDiskValue"
                               Text="{x:Bind ViewModel.LatestStats.DiskUsed, Mode=OneWay, Converter={StaticResource BytesToMBConverter}}" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Process List -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8" Padding="16"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Processes" Style="{ThemeResource SubtitleTextBlockStyle}"
                               AutomationProperties.Name="ProcessListHeader" />
                    <Button Content="Refresh"
                            AutomationProperties.Name="BtnRefreshProcesses"
                            Command="{x:Bind ViewModel.RefreshProcessesCommand}" />
                    <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                  AutomationProperties.Name="ProcessesLoading"
                                  Width="24" Height="24" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox x:Name="PidBox"
                             AutomationProperties.Name="FieldKillPid"
                             PlaceholderText="PID"
                             Width="100" />
                    <Button Content="Kill Process"
                            AutomationProperties.Name="BtnKillProcess"
                            Click="KillProcess_Click" />
                </StackPanel>
                <TextBlock AutomationProperties.Name="MonitoringStatusMessage"
                           Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Border>

        <!-- Process Table -->
        <Border Grid.Row="3"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8" Padding="12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <ScrollViewer>
                <ItemsRepeater AutomationProperties.Name="ProcessTable"
                               ItemsSource="{x:Bind ViewModel.Processes.Processes, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="60,80,80,80,*" Padding="4,6"
                                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                  BorderThickness="0,0,0,1">
                                <TextBlock Grid.Column="0" Text="{Binding Pid}"
                                           AutomationProperties.Name="ProcessPid" FontSize="12" />
                                <TextBlock Grid.Column="1" Text="{Binding User}"
                                           AutomationProperties.Name="ProcessUser" FontSize="12" />
                                <TextBlock Grid.Column="2" Text="{Binding CpuPercent}"
                                           AutomationProperties.Name="ProcessCpu" FontSize="12" />
                                <TextBlock Grid.Column="3" Text="{Binding MemoryPercent}"
                                           AutomationProperties.Name="ProcessMem" FontSize="12" />
                                <TextBlock Grid.Column="4" Text="{Binding Command}"
                                           AutomationProperties.Name="ProcessCommand"
                                           FontSize="12" TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
